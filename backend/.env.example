# Copy to .env and fill in. Never commit .env.
# Get a free key at https://aistudio.google.com/apikey (keep billing OFF to stay on the free tier).
GEMINI_API_KEY=your_key_here

# Optional: which model to use. Verify the current id in Google AI Studio.
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
